<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_sm_pro" model="ir.ui.view">
        <field name="name">res.partner.form.sm.pro</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Reports" name="sm_pro_reports">
                    <group>
                        <field name="sm_report_style_id"
                               options="{'no_create': True, 'no_open': False}"/>
                    </group>
                    <p class="text-muted">
                        When set, this style overrides the company default for any
                        professional report (invoice, sales order, purchase order,
                        delivery slip) addressed to this partner.
                    </p>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
