<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_sm_pro" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sm.pro</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Professional Reports"
                     string="Professional Reports"
                     name="sm_professional_reports">
                    <block title="Default Professional Report Style"
                           name="sm_pro_default_style">
                        <setting id="sm_pro_default_style_setting"
                                 string="Default Style"
                                 help="Style applied to all professional reports for this company by default.">
                            <field name="sm_report_style_id"
                                   options="{'no_create': True}"/>
                            <div class="content-group" invisible="not sm_report_style_id">
                                <button name="%(action_sm_report_style)d"
                                        type="action"
                                        string="Manage Styles"
                                        class="btn-link"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
