<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- BOXED — Card-style with rounded boxes for each section -->
    <template id="sm_pro_template_boxed">
        <!-- Header card -->
        <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 14px; margin-bottom: 12px;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                             style="max-height: 55px;"/>
                        <div t-if="not company.logo" class="sm-pro-company-name"
                             style="font-size: 20px; font-weight: bold;" t-out="company.name"/>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">
                        <div class="sm-pro-doc-title" style="font-size: 22px;">
                            <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                        </div>
                        <div t-if="doc_number" style="color: #888; font-size: 12px;" t-out="doc_number"/>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Two cards side by side -->
        <table style="width: 100%; margin-bottom: 12px;">
            <tr>
                <!-- Partner card -->
                <td style="width: 55%; vertical-align: top; padding-right: 6px;">
                    <div t-attf-style="border: 1px solid #{style.theme_color or '#5c6bc0'}30;
                                        border-radius: 8px; padding: 12px;
                                        border-top: 3px solid #{style.theme_color or '#5c6bc0'};">
                        <div style="font-size: 10px; text-transform: uppercase; color: #999; margin-bottom: 4px;">
                            <t t-if="report_kind == 'purchase'">Vendor</t><t t-else="">Bill To</t>
                        </div>
                        <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                    </div>
                </td>
                <!-- Info card -->
                <td style="width: 45%; vertical-align: top; padding-left: 6px;">
                    <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 12px;">
                        <table class="sm-pro-info-table" style="width: 100%;">
                            <tr t-foreach="info_rows" t-as="row">
                                <td style="font-size: 10px; color: #999;" t-out="row[0]"/>
                                <td style="text-align: right; font-weight: bold;" t-out="row[1]"/>
                            </tr>
                        </table>
                    </div>
                </td>
            </tr>
        </table>

        <!-- Lines in a card -->
        <div style="border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; margin-bottom: 12px;">
            <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        </div>

        <t t-call="sm_professional_reports.sm_pro_totals"/>
        <div t-if="narration" style="margin-top: 12px; padding: 10px; clear: both;
                    border: 1px solid #e0e0e0; border-radius: 8px;">
            <div t-out="narration"/>
        </div>
        <div style="margin-top: 30px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
