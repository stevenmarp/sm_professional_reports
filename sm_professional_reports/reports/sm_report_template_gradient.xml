<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- GRADIENT — Top gradient band with overlapping white card body -->
    <template id="sm_pro_template_gradient">
        <!-- Gradient band -->
        <div t-attf-style="background: linear-gradient(135deg, #{style.theme_color or '#667eea'}, #{style.company_name_color or '#764ba2'});
                            padding: 20px; margin: -10px -10px 0 -10px; color: #fff;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <div style="font-size: 20px; font-weight: bold;" t-out="company.name"/>
                        <div style="font-size: 10px; opacity: 0.8; margin-top: 2px;">
                            <t t-if="company.street"><span t-out="company.street"/></t>
                            <t t-if="company.city"> · <span t-out="company.city"/></t>
                        </div>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">
                        <div style="font-size: 28px; font-weight: bold; letter-spacing: 1px;">
                            <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                        </div>
                    </td>
                </tr>
            </table>
        </div>

        <!-- White card overlapping -->
        <div style="background: #fff; margin: -10px 10px 14px 10px; padding: 16px;
                     border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
            <table style="width: 100%; margin-bottom: 10px;">
                <tr>
                    <td style="width: 55%; vertical-align: top;">
                        <div style="font-size: 10px; text-transform: uppercase; color: #999; margin-bottom: 4px;">
                            <t t-if="report_kind == 'purchase'">Vendor</t><t t-else="">Bill To</t>
                        </div>
                        <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                    </td>
                    <td style="vertical-align: top;">
                        <table class="sm-pro-info-table" style="width: 100%;">
                            <tr t-foreach="info_rows" t-as="row">
                                <td style="color: #999; font-size: 10px;" t-out="row[0]"/>
                                <td style="text-align: right; font-weight: bold;" t-out="row[1]"/>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </div>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        <t t-call="sm_professional_reports.sm_pro_totals"/>
        <div t-if="narration" style="margin-top: 20px; padding: 8px; clear: both;"><div t-out="narration"/></div>
        <div style="margin-top: 30px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
