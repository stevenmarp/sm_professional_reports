<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- TICKET — Receipt / kuitansi style.
         Narrow-focused layout, dashed borders, dot-leader rows for
         amounts, centered company, receipt-like items list, tear-line
         at top and bottom. Completely different visual paradigm. -->
    <template id="sm_pro_template_ticket">
        <!-- Tear line at top -->
        <div t-attf-style="border-top: 2px dashed #{style.theme_color or '#333'};
                           margin-bottom: 16px;"/>

        <!-- Centered company -->
        <div style="text-align: center; margin-bottom: 12px;">
            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                 style="max-height: 45px; margin-bottom: 6px;"/>
            <div class="sm-pro-company-name" style="font-size: 16px; font-weight: bold;"
                 t-out="company.name"/>
            <div style="font-size: 10px; color: #666;">
                <t t-if="company.street"><t t-out="company.street"/></t>
                <t t-if="company.city"> · <t t-out="company.city"/></t>
                <t t-if="company.phone"> · <t t-out="company.phone"/></t>
            </div>
        </div>

        <!-- Dashed separator -->
        <div t-attf-style="border-top: 1px dashed #{style.theme_color or '#333'}; margin-bottom: 10px;"/>

        <!-- Doc title + number centered -->
        <div style="text-align: center; margin-bottom: 10px;">
            <div style="font-size: 14px; font-weight: bold; text-transform: uppercase; letter-spacing: 2px;">
                <t t-call="sm_professional_reports.sm_pro_doc_title"/>
            </div>
            <div style="font-size: 12px; color: #444;" t-out="doc_number"/>
        </div>

        <!-- Dashed separator -->
        <div t-attf-style="border-top: 1px dashed #{style.theme_color or '#333'}; margin-bottom: 10px;"/>

        <!-- Info rows with dot leaders -->
        <table style="width: 100%; margin-bottom: 10px; font-size: 11px;">
            <tr t-foreach="info_rows" t-as="row">
                <td style="width: 30%; color: #666; padding: 2px 0;" t-out="row[0]"/>
                <td style="border-bottom: 1px dotted #ccc; padding: 2px 0;"><!-- dot leader --></td>
                <td style="width: 40%; text-align: right; padding: 2px 0; font-weight: 600;"
                    t-out="row[1]"/>
            </tr>
        </table>

        <!-- Partner (compact, one-block) -->
        <div style="margin-bottom: 10px;">
            <span style="font-size: 10px; color: #999; text-transform: uppercase;">
                <t t-if="report_kind == 'purchase'">Vendor: </t>
                <t t-else="">Customer: </t>
            </span>
            <strong t-if="partner" t-out="partner.name"/>
            <div t-if="partner and partner.vat" style="font-size: 10px; color: #666;">
                VAT: <t t-out="partner.vat"/>
            </div>
        </div>

        <!-- Dashed separator -->
        <div t-attf-style="border-top: 1px dashed #{style.theme_color or '#333'}; margin-bottom: 8px;"/>

        <!-- RECEIPT-STYLE LINE ITEMS (custom — no shared table) -->
        <t t-foreach="lines" t-as="line">
            <div style="margin-bottom: 6px; padding-bottom: 4px; border-bottom: 1px dotted #ddd;">
                <table style="width: 100%; font-size: 11px;">
                    <tr>
                        <td style="vertical-align: top;">
                            <div style="font-weight: bold;">
                                <t t-if="'product_id' in line._fields and line.product_id"
                                   t-out="line.product_id.display_name"/>
                            </div>
                            <div t-if="'name' in line._fields and line.name and line.name != (line.product_id.display_name if 'product_id' in line._fields and line.product_id else '')"
                                 style="font-size: 10px; color: #777; white-space: pre-line;"
                                 t-out="line.name"/>
                        </td>
                        <td style="width: 120px; text-align: right; vertical-align: top; white-space: nowrap;">
                            <!-- Qty -->
                            <t t-if="report_kind == 'invoice'">
                                <t t-out="'%.0f' % (line.quantity or 0)"/>
                            </t>
                            <t t-elif="report_kind == 'sale'">
                                <t t-out="'%.0f' % (line.product_uom_qty or 0)"/>
                            </t>
                            <t t-elif="report_kind == 'purchase'">
                                <t t-out="'%.0f' % (line.product_qty or 0)"/>
                            </t>
                            <t t-elif="report_kind == 'picking'">
                                <t t-out="'%.0f' % (line.quantity or line.product_uom_qty or 0)"/>
                            </t>
                            <t t-if="report_kind in ('sale','invoice','purchase')">
                                × <span t-out="line.price_unit if 'price_unit' in line._fields else 0"
                                        t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                            </t>
                        </td>
                        <t t-if="report_kind in ('sale','invoice','purchase')">
                            <td style="width: 90px; text-align: right; vertical-align: top; font-weight: bold;">
                                <span t-out="line.price_subtotal if 'price_subtotal' in line._fields else 0"
                                      t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                            </td>
                        </t>
                    </tr>
                </table>
            </div>
        </t>

        <!-- Double dashed separator before totals -->
        <div t-attf-style="border-top: 2px dashed #{style.theme_color or '#333'}; margin: 6px 0;"/>

        <!-- Totals with dot leaders (receipt style) -->
        <table style="width: 100%; font-size: 12px;">
            <tr>
                <td style="color: #666;">Subtotal</td>
                <td style="border-bottom: 1px dotted #ccc;"><!-- dot leader --></td>
                <td style="text-align: right; width: 120px;">
                    <span t-out="amount_untaxed or 0"
                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                </td>
            </tr>
            <tr t-if="amount_tax">
                <td style="color: #666;">Tax</td>
                <td style="border-bottom: 1px dotted #ccc;"/>
                <td style="text-align: right;">
                    <span t-out="amount_tax"
                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                </td>
            </tr>
        </table>
        <div t-attf-style="border-top: 1px solid #{style.theme_color or '#333'}; margin: 4px 0;"/>
        <table style="width: 100%; font-size: 15px; font-weight: bold;">
            <tr>
                <td>TOTAL</td>
                <td style="text-align: right;">
                    <span t-out="amount_total or 0"
                          t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                </td>
            </tr>
        </table>
        <div t-attf-style="border-top: 2px solid #{style.theme_color or '#333'}; margin-top: 2px;"/>

        <!-- Amount in words -->
        <div t-if="style.amount_in_words and amount_total"
             style="text-align: center; margin-top: 8px; font-size: 10px; font-style: italic; color: #666;">
            <t t-out="style.get_amount_in_words(amount_total, currency)"/>
        </div>

        <div t-if="narration" style="margin-top: 14px; font-size: 10px; color: #555;
                    text-align: center;">
            <div t-out="narration"/>
        </div>

        <!-- Thank you message -->
        <div style="text-align: center; margin-top: 16px; font-size: 12px; font-weight: bold;">
            ★ Thank You ★
        </div>

        <!-- Tear line at bottom -->
        <div t-attf-style="border-top: 2px dashed #{style.theme_color or '#333'};
                           margin-top: 16px;"/>

        <div style="margin-top: 20px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
