<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         MODERN TEMPLATE
         Solid color header band with white text,
         partner card on the right, accent stripes.
         ============================================ -->
    <template id="sm_pro_template_modern">
        <!-- Colored band -->
        <div class="sm-pro-theme-bg sm-pro-theme-text"
             style="padding: 18px 20px; margin-bottom: 18px;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             style="max-height: 60px; background: white;
                                    padding: 4px; border-radius: 4px;"/>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">
                        <div style="font-size: 24px; font-weight: 300;
                                    letter-spacing: 2px;">
                            <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                        </div>
                        <div t-if="doc_number" style="font-size: 14px; opacity: 0.85;"
                             t-out="doc_number"/>
                    </td>
                </tr>
            </table>
        </div>

        <!-- 2-col info -->
        <table style="width: 100%; margin-bottom: 20px;">
            <tr>
                <td style="width: 60%; vertical-align: top; padding-right: 20px;">
                    <div class="sm-pro-theme-color"
                         style="text-transform: uppercase; font-size: 11px;
                                letter-spacing: 1px; margin-bottom: 6px;">
                        <t t-if="report_kind == 'purchase'">Vendor</t>
                        <t t-else="">Bill To</t>
                    </div>
                    <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                </td>
                <td style="vertical-align: top; padding: 14px;
                          background: #f7f7f7; border-radius: 4px;">
                    <table class="sm-pro-info-table" style="width: 100%;">
                        <tr t-foreach="info_rows" t-as="row">
                            <td style="color: #999; font-size: 10px;
                                       text-transform: uppercase;" t-out="row[0]"/>
                            <td style="text-align: right; font-weight: bold;"
                                t-out="row[1]"/>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>

        <t t-call="sm_professional_reports.sm_pro_totals"/>

        <div t-if="narration" style="margin-top: 30px; padding: 12px;
                                     border-left: 4px solid;
                                     border-color: inherit;
                                     background: #fafafa; clear: both;">
            <div t-out="narration"/>
        </div>

        <div style="margin-top: 30px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
