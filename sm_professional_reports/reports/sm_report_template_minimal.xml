<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         MINIMAL TEMPLATE
         Ultra-clean, no color blocks, lots of
         whitespace, only thin lines as dividers.
         ============================================ -->
    <template id="sm_pro_template_minimal">
        <table style="width: 100%; margin-bottom: 30px;">
            <tr>
                <td style="vertical-align: bottom;">
                    <img t-if="company.logo"
                         t-att-src="image_data_uri(company.logo)"
                         style="max-height: 40px; opacity: 0.8;"/>
                </td>
                <td style="text-align: right; vertical-align: bottom;">
                    <span style="font-size: 10px; color: #bbb; letter-spacing: 2px;
                                 text-transform: uppercase;">
                        <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                    </span>
                </td>
            </tr>
        </table>

        <div style="border-bottom: 1px solid #eee; margin-bottom: 20px;"/>

        <!-- Big doc number -->
        <div t-if="doc_number"
             t-attf-style="font-size: 28px; font-weight: 200;
                            color: #{style.theme_color or '#222'}; margin-bottom: 20px;"
             t-out="doc_number"/>

        <!-- Two-col: partner + info -->
        <table style="width: 100%; margin-bottom: 24px;">
            <tr>
                <td style="width: 50%; vertical-align: top;">
                    <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                </td>
                <td style="vertical-align: top;">
                    <table class="sm-pro-info-table" style="width: 100%;">
                        <tr t-foreach="info_rows" t-as="row">
                            <td style="color: #ccc; font-size: 10px;" t-out="row[0]"/>
                            <td style="text-align: right;" t-out="row[1]"/>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        <t t-call="sm_professional_reports.sm_pro_totals"/>

        <div t-if="narration"
             style="margin-top: 30px; color: #999; font-size: 10px; clear: both;">
            <div t-out="narration"/>
        </div>

        <div style="margin-top: 30px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
