<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sale_order_document">
        <t t-set="style"
           t-value="env['sm.report.style'].get_style_for(doc) or env['sm.report.style'].search([('active','=',True)], limit=1)"/>
        <t t-set="company" t-value="doc.company_id or env.company"/>
        <t t-set="partner" t-value="doc.partner_id"/>
        <t t-set="currency" t-value="doc.currency_id or company.currency_id"/>
        <t t-set="lines" t-value="doc.order_line.filtered(lambda l: not l.display_type)"/>
        <t t-set="amount_untaxed" t-value="doc.amount_untaxed"/>
        <t t-set="amount_tax" t-value="doc.amount_tax"/>
        <t t-set="amount_total" t-value="doc.amount_total"/>
        <t t-set="narration" t-value="doc.note"/>
        <t t-set="report_kind" t-value="'sale'"/>
        <t t-set="doc_number" t-value="doc.name"/>
        <t t-set="info_rows" t-value="[
            ('Number', doc.name or '/'),
            ('Date', doc.date_order and doc.date_order.strftime('%Y-%m-%d') or ''),
            ('Validity', doc.validity_date and doc.validity_date.strftime('%Y-%m-%d') or ''),
            ('Customer Ref', doc.client_order_ref or ''),
            ('Salesperson', doc.user_id.name or ''),
        ]"/>

        <div class="page">
            <t t-call="sm_professional_reports.sm_pro_dispatcher"/>
        </div>
    </template>

    <template id="report_sale_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="sm_professional_reports.report_sale_order_document" t-lang="doc.partner_id.lang or env.user.lang"/>
            </t>
        </t>
    </template>

    <record id="action_report_sm_sale_order" model="ir.actions.report">
        <field name="name">Professional Sales Order / Quotation</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sm_professional_reports.report_sale_order</field>
        <field name="report_file">sm_professional_reports.report_sale_order</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_sm_pro_a4"/>
        <field name="print_report_name">(object.state in ('draft','sent') and 'Quotation - %s' or 'Sales Order - %s') % (object.name or '')</field>
    </record>
</odoo>
