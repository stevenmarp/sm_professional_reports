<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         RETRO TEMPLATE
         Vintage look: serif fonts, double border,
         decorative divider lines, subdued earth tones.
         ============================================ -->
    <template id="sm_pro_template_retro">
        <!-- Decorative top border -->
        <div t-attf-style="border-top: 4px double #{style.theme_color or '#74495f'};
                            border-bottom: 4px double #{style.theme_color or '#74495f'};
                            padding: 12px 0; margin-bottom: 16px;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle; width: 30%;">
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             style="max-height: 60px;"/>
                    </td>
                    <td style="text-align: center; vertical-align: middle;">
                        <div class="sm-pro-company-name"
                             style="font-size: 20px; font-weight: bold;
                                    letter-spacing: 2px; text-transform: uppercase;"
                             t-out="company.name"/>
                        <div style="font-size: 10px; color: #999; margin-top: 2px;">
                            <t t-if="company.street"><t t-out="company.street"/></t>
                            <t t-if="company.city"> · <t t-out="company.city"/></t>
                            <t t-if="company.phone"> · Tel: <t t-out="company.phone"/></t>
                        </div>
                    </td>
                    <td style="text-align: right; vertical-align: middle; width: 30%;">
                        <div class="sm-pro-doc-title" style="font-size: 22px;">
                            <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                        </div>
                        <div t-if="doc_number" style="font-size: 13px; color: #666;"
                             t-out="doc_number"/>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Decorative divider -->
        <div t-attf-style="text-align: center; margin-bottom: 14px;
                            color: #{style.theme_color or '#74495f'}; font-size: 18px;">
            ❧
        </div>

        <table style="width: 100%; margin-bottom: 14px;">
            <tr>
                <td style="width: 55%; vertical-align: top;">
                    <div style="text-transform: uppercase; font-size: 9px;
                                letter-spacing: 2px; color: #999; margin-bottom: 4px;">
                        <t t-if="report_kind == 'purchase'">Vendor</t>
                        <t t-else="">Client</t>
                    </div>
                    <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                </td>
                <td style="vertical-align: top;">
                    <table class="sm-pro-info-table" style="width: 100%;">
                        <tr t-foreach="info_rows" t-as="row">
                            <td style="color: #999; font-size: 10px;
                                       text-transform: uppercase; letter-spacing: 1px;"
                                t-out="row[0]"/>
                            <td style="text-align: right;" t-out="row[1]"/>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        <t t-call="sm_professional_reports.sm_pro_totals"/>

        <div t-if="narration"
             style="margin-top: 24px; padding: 10px; font-style: italic;
                    border-top: 1px solid #ccc; clear: both;">
            <div t-out="narration"/>
        </div>

        <div style="margin-top: 20px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
