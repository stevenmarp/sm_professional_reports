<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         CLASSIC TEMPLATE
         Logo top-left, document title top-right,
         partner box, info table, lines, totals, footer.
         ============================================ -->
    <template id="sm_pro_template_classic">
        <!-- Header band -->
        <table style="width: 100%; margin-bottom: 14px;">
            <tr>
                <td style="vertical-align: middle;">
                    <img t-if="company.logo"
                         t-att-src="image_data_uri(company.logo)"
                         style="max-height: 70px;"/>
                    <div t-else=""
                         class="sm-pro-company-name"
                         style="font-size: 22px; font-weight: bold;"
                         t-out="company.name"/>
                </td>
                <td style="text-align: right; vertical-align: middle;">
                    <div class="sm-pro-doc-title">
                        <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                    </div>
                    <div t-if="doc_number" style="font-size: 14px; color: #666;"
                         t-out="doc_number"/>
                </td>
            </tr>
        </table>

        <!-- Partner + info -->
        <table style="width: 100%; margin-bottom: 14px;">
            <tr>
                <td style="width: 55%; vertical-align: top;
                          padding: 10px; border: 1px solid #ddd;">
                    <div style="text-transform: uppercase; color: #999;
                                font-size: 10px; margin-bottom: 4px;">
                        <t t-if="report_kind == 'purchase'">Vendor</t>
                        <t t-else="">Bill / Ship To</t>
                    </div>
                    <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                </td>
                <td style="width: 5%;"/>
                <td style="vertical-align: top;">
                    <table class="sm-pro-info-table" style="width: 100%;">
                        <tr t-foreach="info_rows" t-as="row">
                            <td style="color: #999; text-transform: uppercase;
                                       font-size: 10px;" t-out="row[0]"/>
                            <td style="text-align: right;" t-out="row[1]"/>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>

        <t t-call="sm_professional_reports.sm_pro_totals"/>

        <div t-if="narration" style="margin-top: 30px; padding: 10px;
                                     background: #fafafa; clear: both;">
            <div t-out="narration"/>
        </div>

        <div style="margin-top: 30px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
