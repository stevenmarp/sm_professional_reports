<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         EXECUTIVE TEMPLATE
         Dark header, gold/premium accents,
         two-tone layout, authority feel.
         ============================================ -->
    <template id="sm_pro_template_executive">
        <!-- Dark header -->
        <div style="background: #1a1a2e; color: #fff;
                    padding: 20px 24px; margin-bottom: 18px;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             style="max-height: 50px; background: #fff;
                                    padding: 4px; border-radius: 4px;"/>
                        <span t-else=""
                              style="font-size: 20px; font-weight: bold;"
                              t-out="company.name"/>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">
                        <div style="font-size: 28px; font-weight: 300;
                                    letter-spacing: 2px;">
                            <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                        </div>
                        <div t-if="doc_number"
                             t-attf-style="font-size: 13px; color: #{style.theme_color or '#d4a843'};"
                             t-out="doc_number"/>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Gold accent line -->
        <div t-attf-style="height: 3px; background: #{style.theme_color or '#d4a843'};
                            margin-bottom: 18px;"/>

        <table style="width: 100%; margin-bottom: 16px;">
            <tr>
                <td style="width: 55%; vertical-align: top;">
                    <div style="text-transform: uppercase; font-size: 9px;
                                color: #999; letter-spacing: 1px; margin-bottom: 4px;">
                        <t t-if="report_kind == 'purchase'">Vendor</t>
                        <t t-else="">Bill To</t>
                    </div>
                    <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                </td>
                <td style="vertical-align: top; background: #fafafa;
                           padding: 12px; border-radius: 4px;">
                    <table class="sm-pro-info-table" style="width: 100%;">
                        <tr t-foreach="info_rows" t-as="row">
                            <td style="color: #999; font-size: 10px;
                                       text-transform: uppercase;" t-out="row[0]"/>
                            <td style="text-align: right; font-weight: bold;"
                                t-out="row[1]"/>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        <t t-call="sm_professional_reports.sm_pro_totals"/>

        <div t-if="narration"
             style="margin-top: 24px; padding: 12px; background: #f5f5f5;
                    border-radius: 4px; color: #555; clear: both;">
            <div t-out="narration"/>
        </div>

        <div style="margin-top: 24px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
