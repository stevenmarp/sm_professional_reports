<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ACCENT — Based on asri_dev "Data Dense" (utility_invoice)
         Logo + company left 60%, customer in full-bordered box right 40%.
         Multi-section line table, detailed calculations style. -->
    <template id="sm_pro_template_accent">
        <!-- Header: company left, customer bordered box right -->
        <table style="width: 100%; margin-bottom: 14px;">
            <tr>
                <td style="width: 55%; vertical-align: top;">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                         style="max-height: 50px; margin-bottom: 6px;"/><br/>
                    <strong class="sm-pro-company-name" style="font-size: 14px;"
                            t-out="company.name"/>
                    <div style="font-size: 10px; color: #555; line-height: 1.4;">
                        <t t-if="company.street"><t t-out="company.street"/><br/></t>
                        <t t-if="company.street2"><t t-out="company.street2"/><br/></t>
                        <t t-if="company.city"><t t-out="company.city"/></t>
                        <t t-if="company.phone"><br/>Tel: <t t-out="company.phone"/></t>
                    </div>
                    <!-- Title positioned below company info -->
                    <div class="sm-pro-doc-title"
                         style="font-size: 20px; font-weight: bold; margin-top: 10px;">
                        <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                    </div>
                </td>
                <!-- Customer in full-bordered box -->
                <td t-attf-style="width: 45%; vertical-align: top; border: 1px solid #{style.theme_color or '#e67e22'};
                                    padding: 8px;">
                    <table style="width: 100%; font-size: 10px;">
                        <tr t-if="partner">
                            <td style="padding: 2px 0;"><strong style="font-size: 12px;" t-out="partner.name"/></td>
                        </tr>
                        <tr t-if="partner and partner.street">
                            <td style="padding: 2px 0;" t-out="partner.street"/>
                        </tr>
                        <tr t-if="partner and partner.city">
                            <td style="padding: 2px 0;">
                                <t t-out="partner.city"/>
                                <t t-if="partner.state_id">, <t t-out="partner.state_id.name"/></t>
                            </td>
                        </tr>
                        <tr t-if="partner and partner.vat">
                            <td style="padding: 2px 0;">VAT: <t t-out="partner.vat"/></td>
                        </tr>
                        <!-- Info rows inside box -->
                        <tr t-foreach="info_rows" t-as="row">
                            <td style="padding: 2px 0;">
                                <span style="color: #999;" t-out="row[0]"/>:
                                <strong t-out="row[1]"/>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <div t-if="doc_number"
             t-attf-style="font-size: 14px; font-weight: bold; color: #{style.theme_color or '#e67e22'};
                            margin-bottom: 8px;"
             t-out="doc_number"/>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        <t t-call="sm_professional_reports.sm_pro_totals"/>

        <div t-if="narration" style="margin-top: 20px; padding: 8px;
                    border-top: 1px dashed #ccc; color: #666; clear: both;">
            <div t-out="narration"/>
        </div>

        <!-- Two-column footer: company + signature -->
        <table style="width: 100%; margin-top: 24px;">
            <tr>
                <td style="width: 50%; vertical-align: top; font-size: 10px;">
                    <t t-if="style.show_bank_in_footer and company.partner_id.bank_ids">
                        <t t-foreach="company.partner_id.bank_ids[:2]" t-as="bank">
                            <strong t-out="bank.bank_name or 'Bank'"/>:
                            <t t-out="bank.acc_number"/><br/>
                        </t>
                    </t>
                </td>
                <td style="width: 50%; text-align: center; font-size: 10px;">
                    <div style="font-style: italic;">Authorized Signature</div>
                    <div style="height: 50px;"/>
                    <div t-attf-style="border-bottom: 1px solid #{style.theme_color or '#e67e22'};
                                        width: 60%; margin: 0 auto;"/>
                </td>
            </tr>
        </table>
        <div style="margin-top: 10px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
