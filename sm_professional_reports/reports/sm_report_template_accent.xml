<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         ACCENT TEMPLATE
         Left accent sidebar stripe, content
         offset to the right, modern asymmetric.
         ============================================ -->
    <template id="sm_pro_template_accent">
        <table style="width: 100%;">
            <tr>
                <!-- Accent sidebar -->
                <td t-attf-style="width: 5px; background: #{style.theme_color or '#74495f'};
                                   border-radius: 3px;"/>
                <td style="padding-left: 18px;">
                    <!-- Header -->
                    <table style="width: 100%; margin-bottom: 18px;">
                        <tr>
                            <td style="vertical-align: middle;">
                                <img t-if="company.logo"
                                     t-att-src="image_data_uri(company.logo)"
                                     style="max-height: 50px;"/>
                                <span t-else="" class="sm-pro-company-name"
                                      style="font-size: 18px; font-weight: bold;"
                                      t-out="company.name"/>
                            </td>
                            <td style="text-align: right; vertical-align: middle;">
                                <div class="sm-pro-doc-title" style="font-size: 22px;">
                                    <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                                </div>
                                <div t-if="doc_number"
                                     style="font-size: 12px; color: #888;"
                                     t-out="doc_number"/>
                            </td>
                        </tr>
                    </table>

                    <!-- Partner + info -->
                    <table style="width: 100%; margin-bottom: 14px;">
                        <tr>
                            <td style="width: 55%; vertical-align: top;">
                                <div class="sm-pro-theme-color"
                                     style="font-size: 10px; text-transform: uppercase;
                                            letter-spacing: 1px; margin-bottom: 4px;">
                                    <t t-if="report_kind == 'purchase'">Vendor</t>
                                    <t t-else="">Bill To</t>
                                </div>
                                <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                            </td>
                            <td style="vertical-align: top;">
                                <table class="sm-pro-info-table" style="width: 100%;">
                                    <tr t-foreach="info_rows" t-as="row">
                                        <td style="color: #999; font-size: 10px;"
                                            t-out="row[0]"/>
                                        <td style="text-align: right;" t-out="row[1]"/>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <t t-call="sm_professional_reports.sm_pro_lines_table"/>
                    <t t-call="sm_professional_reports.sm_pro_totals"/>

                    <div t-if="narration"
                         style="margin-top: 20px; padding: 8px 0;
                                border-top: 1px dashed #ccc; color: #666; clear: both;">
                        <div t-out="narration"/>
                    </div>

                    <div style="margin-top: 20px;"/>
                    <t t-call="sm_professional_reports.sm_pro_footer_block"/>
                </td>
            </tr>
        </table>
    </template>
</odoo>
