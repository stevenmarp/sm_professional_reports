<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         STRIPED TEMPLATE
         Horizontal alternating bands across the
         entire page, table-less header layout,
         colored doc-number badge.
         ============================================ -->
    <template id="sm_pro_template_striped">
        <!-- Top colored band -->
        <div class="sm-pro-theme-bg sm-pro-theme-text"
             style="padding: 14px 18px; margin-bottom: 0;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             style="max-height: 45px; background: #fff;
                                    padding: 3px; border-radius: 4px;"/>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">
                        <span style="font-size: 11px; opacity: 0.8; letter-spacing: 1px;
                                     text-transform: uppercase;">
                            <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                        </span>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Light band with doc number badge -->
        <div t-attf-style="background: #{style.even_row_color or '#f6f0f3'};
                            padding: 14px 18px; margin-bottom: 16px;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <span t-if="doc_number"
                              t-attf-style="display: inline-block; padding: 4px 14px;
                                            background: #{style.theme_color or '#74495f'};
                                            color: #{style.theme_text_color or '#fff'};
                                            border-radius: 20px; font-size: 13px;
                                            font-weight: bold;"
                              t-out="doc_number"/>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">
                        <table class="sm-pro-info-table" style="display: inline-table;">
                            <tr t-foreach="info_rows" t-as="row">
                                <td style="color: #999; font-size: 10px; padding: 1px 8px;"
                                    t-out="row[0]"/>
                                <td style="text-align: right; padding: 1px 0;"
                                    t-out="row[1]"/>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </div>

        <div style="padding: 0 18px;">
            <div style="margin-bottom: 14px;">
                <div style="color: #999; font-size: 9px; text-transform: uppercase;
                            letter-spacing: 1px; margin-bottom: 4px;">
                    <t t-if="report_kind == 'purchase'">Vendor</t>
                    <t t-else="">Bill To</t>
                </div>
                <t t-call="sm_professional_reports.sm_pro_partner_block"/>
            </div>

            <t t-call="sm_professional_reports.sm_pro_lines_table"/>
            <t t-call="sm_professional_reports.sm_pro_totals"/>

            <div t-if="narration"
                 style="margin-top: 24px; padding: 10px; background: #fafafa;
                        border-radius: 4px; clear: both;">
                <div t-out="narration"/>
            </div>

            <div style="margin-top: 24px;"/>
            <t t-call="sm_professional_reports.sm_pro_footer_block"/>
        </div>
    </template>
</odoo>
