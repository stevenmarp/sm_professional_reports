<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- RIBBON — Top colored ribbon bar + badge-style document type -->
    <template id="sm_pro_template_ribbon">
        <!-- Top ribbon -->
        <div t-attf-style="background: #{style.theme_color or '#c62828'};
                            height: 6px; margin: -10px -10px 14px -10px;"/>

        <!-- Header -->
        <table style="width: 100%; margin-bottom: 14px;">
            <tr>
                <td style="vertical-align: middle;">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                         style="max-height: 55px;"/>
                </td>
                <td style="text-align: center; vertical-align: middle;">
                    <strong class="sm-pro-company-name" style="font-size: 15px;"
                            t-out="company.name"/>
                    <div style="font-size: 10px; color: #777;">
                        <t t-if="company.street"><span t-out="company.street"/></t>
                        <t t-if="company.city"> · <span t-out="company.city"/></t>
                    </div>
                </td>
                <td style="text-align: right; vertical-align: middle;">
                    <!-- Badge -->
                    <div t-attf-style="display: inline-block; background: #{style.theme_color or '#c62828'};
                                        color: #{style.theme_text_color or '#fff'};
                                        padding: 6px 16px; border-radius: 20px;
                                        font-weight: bold; font-size: 13px; letter-spacing: 1px;">
                        <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                    </div>
                    <div t-if="doc_number" style="font-size: 11px; color: #888; margin-top: 4px;"
                         t-out="doc_number"/>
                </td>
            </tr>
        </table>

        <!-- Partner + Info -->
        <table style="width: 100%; margin-bottom: 14px;">
            <tr>
                <td style="width: 55%; vertical-align: top;
                           padding: 10px; background: #fafafa; border-radius: 6px;">
                    <div style="font-size: 10px; text-transform: uppercase; color: #999; margin-bottom: 4px;">
                        <t t-if="report_kind == 'purchase'">Vendor</t><t t-else="">Bill To</t>
                    </div>
                    <t t-call="sm_professional_reports.sm_pro_partner_block"/>
                </td>
                <td style="width: 5%;"/>
                <td style="vertical-align: top;">
                    <table class="sm-pro-info-table" style="width: 100%;">
                        <tr t-foreach="info_rows" t-as="row">
                            <td style="color: #999; font-size: 10px;" t-out="row[0]"/>
                            <td style="text-align: right; font-weight: bold;" t-out="row[1]"/>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        <t t-call="sm_professional_reports.sm_pro_totals"/>
        <div t-if="narration" style="margin-top: 20px; padding: 8px; clear: both;"><div t-out="narration"/></div>
        <div style="margin-top: 30px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
