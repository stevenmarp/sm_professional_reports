<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VOUCHER — Based on asri_dev Payment Voucher layout
         Bordered header band with title, 4-column metadata grid,
         No | Description | Debit | Credit style table. -->
    <template id="sm_pro_template_voucher">
        <!-- Bordered header band with title -->
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 10px;">
            <tr>
                <td style="width: 15%; vertical-align: middle;">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                         style="max-height: 50px;"/>
                </td>
                <td t-attf-style="border: 1px solid #000; text-align: center; padding: 6px;
                                   font-weight: bold; font-size: 16px;
                                   background: #{style.theme_color or '#34495e'};
                                   color: #{style.theme_text_color or '#fff'};">
                    <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                </td>
                <td style="width: 15%;"/>
            </tr>
        </table>

        <!-- 4-column metadata grid (Paid To / Doc No, Date / Reference) -->
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 12px;">
            <t t-foreach="info_rows" t-as="row">
                <tr>
                    <td style="width: 18%; padding: 4px 6px; font-weight: bold;" t-out="row[0]"/>
                    <td style="width: 32%; padding: 4px 6px;">: <t t-out="row[1]"/></td>
                    <td style="width: 18%; padding: 4px 6px; font-weight: bold;">
                        <t t-if="row_index == 0">Company</t>
                        <t t-elif="row_index == 1">Partner</t>
                    </td>
                    <td style="width: 32%; padding: 4px 6px;">
                        <t t-if="row_index == 0">: <t t-out="company.name"/></t>
                        <t t-elif="row_index == 1">: <t t-out="partner.name"/></t>
                    </td>
                </tr>
            </t>
        </table>

        <!-- Partner address -->
        <div style="margin-bottom: 14px; padding: 6px 8px; border-left: 3px solid #ccc; font-size: 11px;">
            <t t-call="sm_professional_reports.sm_pro_partner_block"/>
        </div>

        <t t-call="sm_professional_reports.sm_pro_lines_table"/>
        <t t-call="sm_professional_reports.sm_pro_totals"/>

        <div t-if="narration" style="margin-top: 20px; padding: 8px; clear: both;
                    font-size: 11px; background: #f9f9f9;">
            <div t-out="narration"/>
        </div>

        <!-- 4-column signature area -->
        <table style="width: 100%; border-collapse: collapse; margin-top: 30px; font-size: 10px;">
            <tr>
                <td style="border: 1px solid #ccc; text-align: center; padding: 6px; width: 25%;">
                    <strong>Prepared By</strong>
                    <div style="height: 50px;"/>
                    <div style="border-top: 1px solid #999; width: 80%; margin: 0 auto;">_______________</div>
                </td>
                <td style="border: 1px solid #ccc; text-align: center; padding: 6px; width: 25%;">
                    <strong>Checked By</strong>
                    <div style="height: 50px;"/>
                    <div style="border-top: 1px solid #999; width: 80%; margin: 0 auto;">_______________</div>
                </td>
                <td style="border: 1px solid #ccc; text-align: center; padding: 6px; width: 25%;">
                    <strong>Verified By</strong>
                    <div style="height: 50px;"/>
                    <div style="border-top: 1px solid #999; width: 80%; margin: 0 auto;">_______________</div>
                </td>
                <td style="border: 1px solid #ccc; text-align: center; padding: 6px; width: 25%;">
                    <strong>Approved By</strong>
                    <div style="height: 50px;"/>
                    <div style="border-top: 1px solid #999; width: 80%; margin: 0 auto;">_______________</div>
                </td>
            </tr>
        </table>

        <div style="margin-top: 10px;"/>
        <t t-call="sm_professional_reports.sm_pro_footer_block"/>
    </template>
</odoo>
