<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- STRIPED — Based on asri_dev service_charge/overtime mix
         Horizontal colored bands across sections,
         TO box left, info right, strong zebra stripes,
         payment instructions + dual signature at bottom. -->
    <template id="sm_pro_template_striped">
        <!-- Top colored band with company + doc type -->
        <div class="sm-pro-theme-bg sm-pro-theme-text"
             style="padding: 12px 16px; margin-bottom: 0;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                             style="max-height: 40px; background: #fff; padding: 3px; border-radius: 3px;"/>
                    </td>
                    <td style="text-align: center; vertical-align: middle;">
                        <strong style="font-size: 14px;" t-out="company.name"/>
                    </td>
                    <td style="text-align: right; vertical-align: middle; font-size: 10px;
                               letter-spacing: 1px; text-transform: uppercase;">
                        <t t-call="sm_professional_reports.sm_pro_doc_title"/>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Light band with doc number + info -->
        <div t-attf-style="background: #{style.even_row_color or '#eafaf1'};
                            padding: 12px 16px; margin-bottom: 16px;">
            <table style="width: 100%;">
                <tr>
                    <td style="vertical-align: middle;">
                        <span t-if="doc_number"
                              t-attf-style="display: inline-block; padding: 4px 12px;
                                            background: #{style.theme_color or '#27ae60'};
                                            color: #{style.theme_text_color or '#fff'};
                                            border-radius: 16px; font-size: 12px; font-weight: bold;"
                              t-out="doc_number"/>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">
                        <table class="sm-pro-info-table" style="display: inline-table;">
                            <tr t-foreach="info_rows" t-as="row">
                                <td style="color: #666; font-size: 10px; padding: 1px 6px;"
                                    t-out="row[0]"/>
                                <td style="text-align: right; padding: 1px 0; font-weight: bold;"
                                    t-out="row[1]"/>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Partner -->
        <div style="padding: 0 16px; margin-bottom: 14px;">
            <div style="color: #999; font-size: 9px; text-transform: uppercase;
                        letter-spacing: 1px; margin-bottom: 4px;">
                <t t-if="report_kind == 'purchase'">Vendor</t>
                <t t-else="">Bill To</t>
            </div>
            <t t-call="sm_professional_reports.sm_pro_partner_block"/>
        </div>

        <div style="padding: 0 16px;">
            <t t-call="sm_professional_reports.sm_pro_lines_table"/>
            <t t-call="sm_professional_reports.sm_pro_totals"/>

            <div t-if="narration" style="margin-top: 20px; padding: 8px;
                        background: #fafafa; border-radius: 4px; clear: both;">
                <div t-out="narration"/>
            </div>

            <!-- Dual signature (POM style: developed by / managed by) -->
            <table style="width: 100%; margin-top: 30px;">
                <tr>
                    <td style="width: 50%; vertical-align: top;">
                        <div style="font-style: italic; font-size: 10px;">
                            <strong>Prepared by</strong>
                        </div>
                        <div style="height: 40px;"/>
                        <div style="font-size: 10px;">___________________</div>
                    </td>
                    <td style="width: 50%; text-align: right; vertical-align: top;">
                        <div style="font-style: italic; font-size: 10px;">
                            <strong>Authorized by</strong>
                        </div>
                        <div style="height: 40px;"/>
                        <div style="font-size: 10px;">___________________</div>
                    </td>
                </tr>
            </table>

            <div style="margin-top: 14px;"/>
            <t t-call="sm_professional_reports.sm_pro_footer_block"/>
        </div>
    </template>
</odoo>
